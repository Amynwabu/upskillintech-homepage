# Frontend Environment Variables
VITE_API_URL=http://localhost:3000

# Backend Environment Variables (used during build if needed)
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5432/upskillintech

# Email Configuration
SENDGRID_API_KEY=your_sendgrid_api_key_here
SMTP_FROM_EMAIL=noreply@upskillintech.com

# GitHub Actions Secrets (set in repository settings, not in .env file)
# HOSTINGER_SERVER - Your Hostinger FTP/SFTP server address
# HOSTINGER_USERNAME - Your Hostinger FTP/SFTP username
# HOSTINGER_PASSWORD - Your Hostinger FTP/SFTP password
# VITE_API_URL - Production API URL
